{
  "base_keymap": "VSCode",
  "edit_predictions": {
    "provider": "zed"
  },
  "restore_on_startup": "none",
  "session": {
    "trust_all_worktrees": true,
  },
  "project_panel": {
    "hide_hidden": true,
  },
  "agent": {
    "default_model": {
      "provider": "zed.dev",
      "model": "claude-sonnet-4-latest",
    },
  },
  "diagnostics": {
    "inline": {
      "enabled": true,
      "update_debounce_ms": 150,
      "padding": 4,
      "min_column": 0,
      "max_severity": null,
    },
  },
  "terminal": {
    "dock": "right",
    "shell": {
      "with_arguments": {
        "program": "/usr/local/bin/fish",
        "args": ["-l"],
      },
    },
  },
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "GitHub Dark",
  },
  "vim_mode": true,
  "ui_font_size": 16,
  "buffer_font_size": 20.0,
  "cursor_blink": false,
  "gutter": {
    "line_numbers": false,
  },
  "status_bar": {
    "experimental.show": false,
  },
  "file_types": {
    "Rise": ["rise"],
  },
  "title_bar": {
    "show_user_picture": false,
    "show_sign_in": false,
  },
  "file_scan_exclusions": [
    "**/LICENSE",
    "**/LICENSE.*",
    "target",
    "**/node_modules",
    "**/.jazz2",
    "**/typesense",
    "**/assistant-traces",
    "**/.idea",
    "**/.git",
    "**/.svn",
    "**/.hg",
    "**/CVS",
    "**/.DS_Store",
    "**/Thumbs.db",
    "**/.classpath",
    "**/.settings",
  ],
  "languages": {
    "TypeScript": {
      "formatter": [],
      "format_on_save": "on",
      "code_actions_on_format": {
        "source.fixAll.eslint": true,
      },
    },
  },
}
